<Window x:Class="Alexei.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Alexei.App.ViewModels"
        xmlns:local="clr-namespace:Alexei.App"
        Title="Alexei — L2 Bot" Height="700" Width="1000"
        Background="{StaticResource BgBrush}"
               FontFamily="Consolas" FontSize="13">

    <Window.Resources>
        <local:BarWidthConverter x:Key="BarConverter"/>
    </Window.Resources>

    <DockPanel>
        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgLightBrush}" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ Start Proxy" Command="{Binding StartProxyCommand}"
                        Margin="0,0,8,0" Padding="12,4" Background="#2E7D32" Foreground="White" BorderThickness="0"/>
                <Button Content="■ Stop Proxy" Command="{Binding StopProxyCommand}"
                        Margin="0,0,16,0" Padding="12,4" Background="#C62828" Foreground="White" BorderThickness="0"/>
                <Button Content="🤖 Start Bot" Command="{Binding StartBotCommand}"
                        Margin="0,0,8,0" Padding="12,4" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content="⏹ Stop Bot" Command="{Binding StopBotCommand}"
                        Margin="0,0,16,0" Padding="12,4" Background="#E65100" Foreground="White" BorderThickness="0"/>
                <Button Content="💾 Save Profile" Command="{Binding SaveProfileCommand}"
                        Padding="12,4" Background="#37474F" Foreground="White" BorderThickness="0"/>
                <Button Content="🪑 Test Sit" Command="{Binding TestSitCommand}"
                        Margin="16,0,0,0" Padding="12,4" Background="#6A1B9A" Foreground="White" BorderThickness="0"/>
                <TextBlock Text="{Binding CharName}" Margin="20,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BgLightBrush}" Padding="8,3">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource DimTextBrush}"/>
        </Border>

        <!-- Main tab control -->
        <TabControl BorderThickness="0" Padding="0">

            <!-- Server Tab -->
            <TabItem Header="Server" DataContext="{Binding Server}">
                <StackPanel Margin="16">
                    <TextBlock Text="Active Server" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}"
                              DisplayMemberPath="Name" Width="300" HorizontalAlignment="Left"/>
                    <StackPanel Margin="0,16,0,0" DataContext="{Binding SelectedServer}">
                        <TextBlock Text="{Binding LoginHost, StringFormat='Login: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding GameHost, StringFormat='Game: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding L2Path, StringFormat='L2 Path: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding SkillFormat, StringFormat='Skill Format: {0}'}" Margin="0,4"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Character Tab -->
            <TabItem Header="Character" DataContext="{Binding CharInfo}">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name, StringFormat='Name: {0}'}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Level, StringFormat='Level: {0}'}" Margin="0,8"/>
                        <TextBlock Text="{Binding Exp, StringFormat='Exp: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding Position, StringFormat='Pos: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding TargetId, StringFormat='Target ID: {0}'}" Margin="0,4"/>
                        <TextBlock Text="{Binding IsSitting, StringFormat='Sitting: {0}'}" Margin="0,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <!-- HP Bar -->
                        <TextBlock Text="{Binding HpPct, StringFormat='HP: {0:F1}%'}" Foreground="{StaticResource HpBrush}" Margin="0,0,0,2"/>
                        <Grid Height="20" Margin="0,0,0,8">
                            <Border Background="#3E2723" CornerRadius="3"/>
                            <Border Background="{StaticResource HpBrush}" CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding HpPct, Converter={StaticResource BarConverter}, ConverterParameter=200}"/>
                        </Grid>
                        <TextBlock Text="{Binding CurHp, StringFormat='  {0}'}" Foreground="{StaticResource HpBrush}" FontSize="11"/>

                        <!-- MP Bar -->
                        <TextBlock Text="{Binding MpPct, StringFormat='MP: {0:F1}%'}" Foreground="{StaticResource MpBrush}" Margin="0,8,0,2"/>
                        <Grid Height="20" Margin="0,0,0,8">
                            <Border Background="#0D3B66" CornerRadius="3"/>
                            <Border Background="{StaticResource MpBrush}" CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding MpPct, Converter={StaticResource BarConverter}, ConverterParameter=200}"/>
                        </Grid>

                        <!-- CP Bar -->
                        <TextBlock Text="{Binding CpPct, StringFormat='CP: {0:F1}%'}" Foreground="{StaticResource CpBrush}" Margin="0,8,0,2"/>
                        <Grid Height="20">
                            <Border Background="#4A3800" CornerRadius="3"/>
                            <Border Background="{StaticResource CpBrush}" CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding CpPct, Converter={StaticResource BarConverter}, ConverterParameter=200}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Combat Tab -->
            <TabItem Header="Combat" DataContext="{Binding Combat}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <CheckBox Content="Enable Auto-Combat" IsChecked="{Binding Enabled}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12">
                        <TextBlock Text="Aggro Radius:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding AggroRadius}" Minimum="100" Maximum="3000" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AggroRadius, StringFormat='{}{0:F0}'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Z Height Limit:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding ZHeightLimit}" Minimum="50" Maximum="1000" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ZHeightLimit}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Anchor Leash:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding AnchorLeash}" Minimum="0" Maximum="5000" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AnchorLeash, StringFormat='{}{0:F0}'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <CheckBox Content="Basic Attack" IsChecked="{Binding BasicAttack}" Margin="0,8"/>

                    <!-- Skill Rotation -->
                    <TextBlock Text="Skill Rotation" FontWeight="Bold" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedSkill}"
                                  DisplayMemberPath="Display" Width="220"                                  ToolTip="Select from your character's skills"/>
                        <Button Content="+ Add" Command="{Binding AddSkillCommand}"
                                Margin="6,0,4,0" Padding="10,3" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                        <Button Content="− Remove" Command="{Binding RemoveSkillCommand}"
                                Padding="10,3" Background="#B71C1C" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding SkillRotation}" SelectedItem="{Binding SelectedRotationEntry}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="{StaticResource BgLightBrush}"
                              RowBackground="{StaticResource BgBrush}" GridLinesVisibility="Horizontal"
                              BorderThickness="0" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                            <DataGridTextColumn Header="Skill ID" Binding="{Binding SkillId}" Width="80"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60"/>
                            <DataGridTextColumn Header="Min MP%" Binding="{Binding MinMpPct}" Width="80"/>
                            <DataGridTextColumn Header="CD (ms)" Binding="{Binding CooldownMs}" Width="80"/>
                            <DataGridTextColumn Header="Target HP ≤" Binding="{Binding TargetHpBelowPct}" Width="90"/>
                            <DataGridTextColumn Header="Target HP ≥" Binding="{Binding TargetHpAbovePct}" Width="90"/>
                            <DataGridTextColumn Header="Max Range" Binding="{Binding MaxRange}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Spoil Mode -->
                    <TextBlock Text="Spoil Mode" FontWeight="Bold" Margin="0,16,0,4"/>
                    <CheckBox Content="Enable Spoil Before Attack" IsChecked="{Binding SpoilEnabled}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Spoil Skill ID:" VerticalAlignment="Center" Width="110"/>
                        <TextBox Text="{Binding SpoilSkillId}" Width="70"/>
                        <Button Content="← Use Selected" Command="{Binding SetSpoilSkillCommand}"
                                Margin="8,0,0,0" Padding="8,3" Background="#37474F" Foreground="White" BorderThickness="0"
                                ToolTip="Set Spoil Skill ID from the selected skill above"/>
                        <TextBlock Text="Max Attempts:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                        <TextBox Text="{Binding SpoilMaxAttempts}" Width="40"/>
                    </StackPanel>
                    <CheckBox Content="Enable Sweep After Kill" IsChecked="{Binding SweepEnabled}" Margin="0,6,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Sweep Skill ID:" VerticalAlignment="Center" Width="110"/>
                        <TextBox Text="{Binding SweepSkillId}" Width="70"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Buffs Tab -->
            <TabItem Header="Buffs" DataContext="{Binding Buffs}">
                <StackPanel Margin="16">
                    <CheckBox Content="Enable Auto-Buff" IsChecked="{Binding Enabled}"/>
                    <TextBlock Text="Buff List" FontWeight="Bold" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedSkill}"
                                  DisplayMemberPath="Display" Width="220"                                  ToolTip="Select from your character's skills"/>
                        <Button Content="+ Add Buff" Command="{Binding AddBuffCommand}"
                                Margin="6,0,4,0" Padding="10,3" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                        <Button Content="− Remove" Command="{Binding RemoveBuffCommand}"
                                Padding="10,3" Background="#B71C1C" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding BuffList}" SelectedItem="{Binding SelectedBuff}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="{StaticResource BgLightBrush}"
                              RowBackground="{StaticResource BgBrush}" GridLinesVisibility="Horizontal"
                              BorderThickness="0" MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                            <DataGridTextColumn Header="Skill ID" Binding="{Binding SkillId}" Width="80"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60"/>
                            <DataGridTextColumn Header="Interval (s)" Binding="{Binding IntervalSec}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Rebuff" Binding="{Binding RebuffOnMissing}" Width="60"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- Party Tab -->
            <TabItem Header="Party" DataContext="{Binding Party}">
                <StackPanel Margin="16">
                    <CheckBox Content="Enable Party Support" IsChecked="{Binding Enabled}"/>
                    <TextBlock Text="Heal Rules" FontWeight="Bold" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedHealSkill}"
                                  DisplayMemberPath="Display" Width="220"                                  ToolTip="Select heal skill from your character's skills"/>
                        <Button Content="+ Add Heal" Command="{Binding AddHealRuleCommand}"
                                Margin="6,0,4,0" Padding="10,3" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                        <Button Content="− Remove" Command="{Binding RemoveHealRuleCommand}"
                                Padding="10,3" Background="#B71C1C" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding HealRules}" SelectedItem="{Binding SelectedHealRule}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="{StaticResource BgLightBrush}"
                              RowBackground="{StaticResource BgBrush}" BorderThickness="0" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                            <DataGridTextColumn Header="Skill ID" Binding="{Binding SkillId}" Width="80"/>
                            <DataGridTextColumn Header="HP Threshold" Binding="{Binding HpThreshold}" Width="100"/>
                            <DataGridTextColumn Header="Min MP%" Binding="{Binding MpMinPct}" Width="80"/>
                            <DataGridTextColumn Header="CD (ms)" Binding="{Binding CooldownMs}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="Party Buff Rules" FontWeight="Bold" Margin="0,16,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedBuffSkill}"
                                  DisplayMemberPath="Display" Width="220"                                  ToolTip="Select buff skill from your character's skills"/>
                        <Button Content="+ Add Buff" Command="{Binding AddBuffRuleCommand}"
                                Margin="6,0,4,0" Padding="10,3" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                        <Button Content="− Remove" Command="{Binding RemoveBuffRuleCommand}"
                                Padding="10,3" Background="#B71C1C" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding BuffRules}" SelectedItem="{Binding SelectedBuffRule}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="{StaticResource BgLightBrush}"
                              RowBackground="{StaticResource BgBrush}" BorderThickness="0" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                            <DataGridTextColumn Header="Skill ID" Binding="{Binding SkillId}" Width="80"/>
                            <DataGridTextColumn Header="Interval (s)" Binding="{Binding IntervalSec}" Width="90"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- Loot Tab -->
            <TabItem Header="Loot" DataContext="{Binding Loot}">
                <StackPanel Margin="16">
                    <CheckBox Content="Enable Auto-Loot" IsChecked="{Binding Enabled}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12">
                        <TextBlock Text="Pickup Radius:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding Radius}" Minimum="50" Maximum="1000" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Radius, StringFormat='{}{0:F0}'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Recovery Tab -->
            <TabItem Header="Recovery" DataContext="{Binding Recovery}">
                <StackPanel Margin="16">
                    <CheckBox Content="Enable Recovery (Sit/Regen)" IsChecked="{Binding Enabled}"/>
                    <TextBlock Text="Sit when:" FontWeight="Bold" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="HP below:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding SitBelowHp}" Minimum="0" Maximum="100" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SitBelowHp, StringFormat='{}{0:F0}%'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="MP below:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding SitBelowMp}" Minimum="0" Maximum="100" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SitBelowMp, StringFormat='{}{0:F0}%'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Stand when:" FontWeight="Bold" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="HP above:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding StandAboveHp}" Minimum="0" Maximum="100" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StandAboveHp, StringFormat='{}{0:F0}%'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="MP above:" VerticalAlignment="Center" Width="120"/>
                        <Slider Value="{Binding StandAboveMp}" Minimum="0" Maximum="100" Width="200" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StandAboveMp, StringFormat='{}{0:F0}%'}" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Monsters Tab -->
            <TabItem Header="Monsters" DataContext="{Binding Monsters}">
                <DockPanel Margin="16">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding TotalCount, StringFormat='Total NPCs: {0}'}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding Monsters}" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="{StaticResource BgLightBrush}"                              RowBackground="{StaticResource BgBrush}" GridLinesVisibility="Horizontal" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="NPC ID" Binding="{Binding NpcId}" Width="80"/>
                            <DataGridTextColumn Header="Distance" Binding="{Binding Distance}" Width="80"/>
                            <DataGridTextColumn Header="HP%" Binding="{Binding HpPercent}" Width="60"/>
                            <DataGridCheckBoxColumn Header="Atk" Binding="{Binding IsAttackable}" Width="40"/>
                            <DataGridCheckBoxColumn Header="Dead" Binding="{Binding IsDead}" Width="50"/>
                            <DataGridTextColumn Header="ObjID" Binding="{Binding ObjectId}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Log Tab -->
            <TabItem Header="Log" DataContext="{Binding Log}">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Show Packets" IsChecked="{Binding ShowPackets}" Margin="0,0,16,0"/>
                        <Button Content="Clear" Padding="8,2" Background="#37474F" Foreground="White" BorderThickness="0"
                                Click="ClearLog_Click"/>
                        <Button Content="Copy All" Padding="8,2" Background="#37474F" Foreground="White" BorderThickness="0"
                                Margin="8,0,0,0" Click="CopyLog_Click"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Entries}" DisplayMemberPath="Display"
                             Background="{StaticResource BgBrush}" Foreground="#B0BEC5"
                             FontFamily="Consolas" FontSize="11" BorderThickness="0"
                             x:Name="LogListBox"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
