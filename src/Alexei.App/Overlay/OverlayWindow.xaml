<Window x:Class="Alexei.App.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Alexei.App.Overlay"
        Title="Alexei Overlay"
        Width="220" Height="140"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <local:PctToWidthConverter x:Key="PctToWidth"/>
    </Window.Resources>

    <Border Background="#CC1E1E2E" CornerRadius="8" Padding="10" BorderBrush="#40FFFFFF" BorderThickness="1">
        <StackPanel>
            <!-- Character name -->
            <TextBlock Text="{Binding CharName}" Foreground="#00BFA5" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>

            <!-- HP bar -->
            <Grid Height="14" Margin="0,6,0,2">
                <Border Background="#3E2723" CornerRadius="2"/>
                <Border Background="#C62828" CornerRadius="2" HorizontalAlignment="Left"
                        Width="{Binding HpPct, Converter={StaticResource PctToWidth}, ConverterParameter=200}"/>
                <TextBlock Text="{Binding HpPct, StringFormat='HP {0:F0}%'}" Foreground="White" FontSize="9"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>

            <!-- MP bar -->
            <Grid Height="14" Margin="0,2">
                <Border Background="#0D3B66" CornerRadius="2"/>
                <Border Background="#1565C0" CornerRadius="2" HorizontalAlignment="Left"
                        Width="{Binding MpPct, Converter={StaticResource PctToWidth}, ConverterParameter=200}"/>
                <TextBlock Text="{Binding MpPct, StringFormat='MP {0:F0}%'}" Foreground="White" FontSize="9"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>

            <!-- CP bar -->
            <Grid Height="14" Margin="0,2">
                <Border Background="#4A3800" CornerRadius="2"/>
                <Border Background="#F9A825" CornerRadius="2" HorizontalAlignment="Left"
                        Width="{Binding CpPct, Converter={StaticResource PctToWidth}, ConverterParameter=200}"/>
                <TextBlock Text="{Binding CpPct, StringFormat='CP {0:F0}%'}" Foreground="White" FontSize="9"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>

            <!-- Target + Status -->
            <TextBlock Text="{Binding TargetInfo}" Foreground="#B0BEC5" FontSize="10" Margin="0,4,0,0" FontFamily="Consolas"/>
            <TextBlock Text="{Binding BotStatus}" Foreground="#00BFA5" FontSize="10" FontFamily="Consolas"/>
        </StackPanel>
    </Border>


</Window>
